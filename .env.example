# Copy to .env and fill in. .env is gitignored.

# --- Book / scraping ---
BOOK_BASE_DIR=bqg/biqu59096
BOOK_SOURCE_URL=https://www.52shuku.net/...

# --- Default OpenAI-compatible endpoint (local vLLM/Ollama, OpenAI, DeepSeek) ---
# Local vLLM example:   LLM_API_BASE=http://localhost:8000/v1
# Local Ollama example: LLM_API_BASE=http://localhost:11434/v1
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=sk-local
LLM_MODEL=qwen2.5-72b-instruct

# --- Optional cloud providers (only if a role points at them in config.yaml) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline defaults (optional) ---
TRANSLATION_LIMIT=
